
# ============================================
# UNIFIED SOCIAL MEDIA API
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your credentials
# Never commit .env to version control!
# ============================================

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME="Unified Social Media API"
DEBUG=true
SECRET_KEY="change-this-to-a-secure-random-string-in-production"
API_V1_PREFIX="/api/v1"

# ============================================
# DATABASE
# ============================================
# For development with Docker (PostgreSQL):
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/unified_social"
DATABASE_SYNC_URL="postgresql://postgres:postgres@localhost:5432/unified_social"

# For development without Docker (SQLite - fallback):
# DATABASE_URL="sqlite+aiosqlite:///./unified_social.db"
# DATABASE_SYNC_URL="sqlite:///./unified_social.db"

# ============================================
# REDIS & CELERY (Async Task Queue)
# ============================================
# With Docker Redis:
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# Without Redis (fallback - tasks run synchronously):
# REDIS_URL="memory://"
# CELERY_BROKER_URL="memory://"
# CELERY_RESULT_BACKEND="rpc://"

# ============================================
# MOCK MODE (Testing without real credentials)
# ============================================
# Set to true for development without API keys
# Set to false when you have real credentials
MOCK_OAUTH=true

# ============================================
# YOUTUBE / GOOGLE API
# ============================================
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID="your_youtube_client_id_here"
YOUTUBE_CLIENT_SECRET="your_youtube_client_secret_here"
YOUTUBE_API_KEY="your_youtube_api_key_here"

# ============================================
# TWITTER / X API
# ============================================
# Get these from Twitter Developer Portal:
# https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY="your_twitter_api_key_here"
TWITTER_API_SECRET="your_twitter_api_secret_here"
TWITTER_BEARER_TOKEN="your_twitter_bearer_token_here"

# ============================================
# FACEBOOK & INSTAGRAM (Meta)
# ============================================
# Get these from Meta for Developers:
# https://developers.facebook.com/apps/
META_APP_ID="your_facebook_app_id_here"
META_APP_SECRET="your_facebook_app_secret_here"
META_GRAPH_API_VERSION="v18.0"

# ============================================
# LINKEDIN API
# ============================================
# Get these from LinkedIn Developers:
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"

# ============================================
# WHATSAPP BUSINESS API
# ============================================
# Get these from Meta for Developers (WhatsApp product):
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_number_id_here"
WHATSAPP_ACCESS_TOKEN="your_whatsapp_access_token_here"

# ============================================
# INSTAGRAM (Standalone - same as Meta above)
# ============================================
# Uses same credentials as Meta (Facebook)
# Instagram Business account required for posting
